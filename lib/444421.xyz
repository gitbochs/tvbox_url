_blank"></a>&nbsp;<a href="/index.php/vod/search/actor/%E6%9D%BE%E5%B0%BE%E8%B0%95.html" target="_blank">松尾谕</a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search/actor/%E5%A7%9C%E7%95%85%E9%9B%84.html" target="_blank">姜畅雄</a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search/actor/%E6%98%A0%E7%BE%8E%E8%97%8F%E8%89%AF.html" target="_blank">映美藏良</a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search/actor/%E6%9D%89%E9%87%8E%E9%81%A5%E4%BA%AE.html" target="_blank">杉野遥亮</a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search/actor/%E9%9D%92%E6%9C%A8%E6%B2%99%E8%80%B6%E5%8A%A0.html" target="_blank">青木沙耶加</a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search/actor/%E5%A4%A7%E5%A0%80%E6%B5%A9%E4%B8%80.html" target="_blank">大堀浩一</a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search/actor/%E5%A4%A7%E6%B0%B4%E6%B4%8B%E4%BB%8B.html" target="_blank">大水洋介</a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search.html" target="_blank"></a>&nbsp;<a href="/index.php/vod/search/actor/%E5%90%8D%E6%9D%91%E8%BE%B0.html" target="_blank">名村辰</a>&nbsp;</div><div class="module-item-style video-text">　（1）「遺体は一体……」（遗体究竟……）　　出演：上川隆也（主演） 、高桥洋、樋口幸平 等　　剧情简介：　　资深刑警·樱庭孝夫（上川隆也 饰）前往独栋住宅调查，发现二楼卧室有一男一女两具遗体。然而，</div></div></div><div class="module-item-titlebox"><a href="/index.php/vod/play/id/181123/sid/1/nid/1.html" class="module-item-title" title="世界奇妙物语2026夏季特别篇">世界奇妙物语2026夏季特别篇</a></div><div class="module-item-text">HD</div></div><div class="module-item"><div class="module-item-cover"><div class="module-item-pic"><a href="/index.php/vod/play/id/181110/sid/1/nid/1.html" title="午夜电梯" ><i class="icon-play"></i></a><img class="lazy lazyloaded" data-src="https://pic3.yzzyimg.online/upload/vod/2026-06-28/202606281782611223.jpg" src="/template/mxone/mxstatic/image/loading.gif" onerror="javascript:this.src='/template/mxone/mxstatic/image/zanwupic.png'" alt="午夜电梯"><div class="loading"></div></div><div class="module-item-caption"><span>2026</span><span class="video-class">电影</span><span>大陆</span></div><div class="module-item-content"><div class="module-item-style video-name"><a href="/index.php/vod/play/id/181110/sid/1/nid/1.html" title="午夜电梯">午夜电梯</a></div><div class="module-item-style video-tag"><a href="/index.php/vod/search/actor/%E5%88%98%E5%8D%9A.html" target="_blank">刘博</a>&nbsp;<a href="/index.php/vod/search/actor/%E8%B5%B5%E5%B8%85.html" target="_blank">赵帅</a>&nbsp;</div><div class="module-item-style video-text">　　午夜子时，血色符纸在电梯口燃尽，连接阴阳的“鬼奠梯”就此开启。 因为老宅拆迁，落魄女作家李心凌被迫回到重庆。然而，她惊恐地发现，每到午夜12点，那部废弃的电梯都会自行启动。电梯每开一次门，就有一位</div></div></div><div class="module-item-titlebox"><a href="/index.php/vod/play/id/181110/sid/1/nid/1.html" class="module-item-title" title="午夜电梯">午夜电梯</a></div><div class="module-item-text">HD</div></div><div class="module-item"><div class="module-item-cover"><div class="module-item-pic"><a href="/index.php/vod/play/id/181008/sid/1/nid/1.html" title="幻犬诳猫" ><i class="icon-play"></i></a><img class="lazy lazyloaded" data-src="https://pic3.yzzyimg.online/upload/vod/2026-06-27/202606271782533776.jpg" src="/template/mxone/mxstatic/image/loading.gif" onerror="javascript:this.src='/template/mxone/mxstatic/image/zanwupic.png'" alt="幻犬诳猫"><div class="loading"></div></div><div class="module-item-caption"><span>2025</span><span class="video-class">电影</span><span>日本</span></div><div class="module-item-content"><div class="module-item-style video-name"><a href="/index.php/vod/play/id/181008/sid/1/nid/1.html" title="幻犬诳猫">幻犬诳猫</a></div><div class="module-item-style video-tag"><a href="/index.php/vod/search/actor/%E9%AB%98%E6%9D%89%E7%9C%9F%E5%AE%99.html" target="_blank">高杉真宙</a>&nbsp;<a href="/index.php/vod/search/actor/%E4%BC%8A%E8%97%A4%E4%B8%87%E7%90%86%E5%8D%8E.html" target="_blank">伊藤万理华</a>&nbsp;<a href="/index.php/vod/search/actor/%E6%B7%B1%E5%B7%9D%E9%BA%BB%E8%A1%A3.html" target="_blank">深川麻衣</a>&nbsp;<a href="/index.php/vod/search/actor/%E5%AE%89%E8%97%A4%E8%A3%95%E5%AD%90.html" target="_blank">安藤裕子</a>&nbsp;<a href="/index.php/vod/search/actor/%E5%90%91%E9%87%8C%E7%A5%90%E9%A6%99.html" target="_blank">向里祐香</a>&nbsp;<a href="/index.php/vod/search/actor/%E5%B8%8C%E7%A7%91%E7%BD%97%E5%B8%8C.html" target="_blank">希科罗希</a>&nbsp;<a href="/index.php/vod/search/actor/%E9%93%83%E6%9C%A8%E7%A0%82%E7%BE%BD.html" target="_blank">铃木砂羽</a>&nbsp;<a href="/index.php/vod/search/actor/%E6%9D%BE%E5%86%88%E4%BE%9D%E9%83%BD%E7%BE%8E.html" target="_blank">松冈依都美</a>&nbsp;<a href="/index.php/vod/search/actor/%E6%A3%AE%E7%94%B0%E6%83%B3.html" target="_blank">森田想</a>&nbsp;<a href="/index.php/vod/search/actor/%E9%AB%98%E5%B0%BE%E6%82%A0%E5%B8%8C.html" target="_blank">高尾悠希</a>&nbsp;<a href="/index.php/vod/search/actor/%E5%90%8E%E8%97%A4%E5%88%9A%E8%8C%83.html" target="_blank">后藤刚范</a>&nbsp;<a href="/index.php/vod/search/actor/%E9%95%BF%E5%8F%8B%E9%83%81%E7%9C%9F.html" target="_blank">长友郁真</a>&nbsp;<a href="/index.php/vod/search/actor/%E3%81%AF%E3%81%AA%E3%82%8F.html" target="_blank">はなわ</a>&nbsp;<a href="/index.php/vod/search/actor/%E5%AE%89%E7%94%B0%E6%98%BE.html" target="_blank">安田显</a>&nbsp;<a href="/index.php/vod/search/actor/%E4%BD%99%E8%B4%B5%E7%BE%8E%E5%AD%90.html" target="_blank">余贵美子</a>&nbsp;<a href="/index.php/vod/search/actor/%E6%9F%84%E6%9C%AC%E6%98%8E.html" target="_blank">柄本明</a>&nbsp;</div><div class="module-item-style video-text">　　羽猫家は、みんな「嘘つき」である――。空想の世界に生きる母、愛人の元に逃げる父、その全てに反発する姉、そして思い付きで動く適当な祖父と比較的まともな祖母。そんな家の長男として生まれた山吹は、幼い頃</div></div></div><div class="module-item-titlebox"><a href="/index.php/vod/play/id/181008/sid/1/nid/1.html" class="module-item-title" title="幻犬诳猫">幻犬诳猫</a></div><div class="module-item-text">HD</div></div><div class="module-item"><div class="module-item-cover"><div class="module-item-pic"><a href="/index.php/vod/play/id/180999/sid/1/nid/1.html" title="森中有林" ><i class="icon-play"></i></a><img class="lazy lazyloaded" data-src="https://pps.vodfeiss.com/upload/vod/20260627-1/406c48a08ca2ec539f6ac0dc319e29f0.jpg" src="/template/mxone/mxstatic/image/loading.gif" onerror="javascript:this.src='/template/mxone/mxstatic/image/zanwupic.png'" alt="森中有林"><div class="loading"></div></div><div class="module-item-caption"><span>2026</span><span class="video-class">电影</span><span>大陆</span></div><div class="module-item-content"><div class="module-item-style video-name"><a href="/index.php/vod/play/id/180999/sid/1/nid/1.html" title="森中有林">森中有林</a></div><div class="module-item-style video-tag"><a href="/index.php/vod/search/actor/%E4%BA%8E%E5%92%8C%E4%BC%9F.html" target="_blank">于和伟</a>&nbsp;<a href="/index.php/vod/search/actor/%E9%AB%98%E5%9C%86%E5%9C%86.html" target="_blank">高圆圆</a>&nbsp;<a href="/index.php/vod/search/actor/%E9%9F%A9%E5%BA%9A.html" target="_blank">韩庚</a>&nbsp;<a href="/index.php/vod/search/actor/%E5%BC%A0%E5%A4%A9%E7%88%B1.html" target="_blank">张天爱</a>&nbsp;<a href="/index.php/vod/search/actor/%E4%B9%94%E6%9D%89.html" target="_blank">乔杉</a>&nbsp;<a href="/index.php/vod/search/actor/%E5%A4%8F%E4%B9%8B%E5%85%89.html" target="_blank">夏之光</a>&nbsp;<a href="/index.php/vod/search/actor/%E9%82%AC%E5%AE%B6%E6%A5%B7.html" target="_blank">邬家楷</a>&nbsp;<a href="/index.php/vod/search/actor/%E8%B0%A2%E5%8F%AF%E5%AF%85.html" target="_blank">谢可寅</a>&nbsp;<a href="/index.php/vod/search/actor/%E5%AE%8B%E5%B0%8F%E5%AE%9D.html" target="_blank">宋小宝</a>&nbsp;<a href="/index.php/vod/se