<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="robots" content="noindex, nofollow">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>LIBVIO — 域名停用通知</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #111214;
    --bg2:       #18191d;
    --bg3:       #1e1f24;
    --border:    #2a2b30;
    --border-hi: #38393f;
    --orange:    #e87c1e;
    --orange-dim: rgba(232,124,30,0.12);
    --orange-border: rgba(232,124,30,0.30);
    --text:      #d8d9dc;
    --text-hi:   #edeef0;
    --muted:     #6b6d75;
    --danger:    #d95454;
    --danger-bg: rgba(217,84,84,0.10);
    --danger-border: rgba(217,84,84,0.25);
  }

  html, body {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0;
  }

  /* ── Top bar ── */
  .topbar {
    width: 100%;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 46px;
    flex-shrink: 0;
  }

  .logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 500;
    color: var(--orange);
    letter-spacing: 2px;
    text-decoration: none;
  }

  .topbar-status {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--danger);
  }

  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--danger);
    animation: blink 1.8s ease infinite;
    flex-shrink: 0;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  /* ── Main wrap ── */
  .main {
    width: 100%;
    max-width: 520px;
    padding: 36px 16px 48px;
    animation: fadeIn .35s ease both;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Alert block ── */
  .alert {
    background: var(--danger-bg);
    border: 1px solid var(--danger-border);
    border-radius: 4px;
    padding: 16px 18px;
    margin-bottom: 28px;
  }

  .alert-title {
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--danger);
    letter-spacing: 1px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .domain-strike-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .domain-strike {
    font-family: 'JetBrains Mono', monospace;
    font-size: 17px;
    color: var(--danger);
    opacity: 0.55;
    text-decoration: line-through;
    text-decoration-color: var(--danger);
    text-decoration-thickness: 1.5px;
  }

  .x-mark {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--danger);
    opacity: 0.75;
    background: rgba(217,84,84,0.15);
    border: 1px solid var(--danger-border);
    border-radius: 3px;
    padding: 2px 8px;
    flex-shrink: 0;
  }

  .alert-desc {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ── Countdown ── */
  .countdown {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed var(--danger-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .countdown-label {
    font-size: 10.5px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--danger);
    letter-spacing: 1.2px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 7px;
    opacity: 0.9;
  }

  .countdown-time {
    display: flex;
    align-items: baseline;
    gap: 4px;
    font-family: 'JetBrains Mono', monospace;
  }

  .cd-unit {
    display: flex;
    align-items: baseline;
    gap: 3px;
  }

  .cd-num {
    font-size: 22px;
    font-weight: 600;
    color: var(--danger);
    min-width: 30px;
    text-align: center;
    letter-spacing: 1px;
    font-variant-numeric: tabular-nums;
  }

  .cd-tag {
    font-size: 10px;
    color: var(--muted);
  }

  .cd-sep {
    font-size: 18px;
    color: var(--danger);
    opacity: 0.4;
    transform: translateY(-1px);
  }

  /* ── Section ── */
  .section { margin-bottom: 22px; }

  .section-head {
    padding-bottom: 7px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  .section-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── Table rows ── */
  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background .12s;
    gap: 12px;
  }

  .row:hover { background: var(--bg3); }

  .row.featured {
    background: var(--orange-dim);
    border-color: var(--orange-border);
    border-top: 1px solid var(--orange-border);
  }

  .row.featured:hover { background: rgba(232,124,30,0.18); }

  .row-left {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    width: 20px;
    flex-shrink: 0;
    text-align: right;
  }

  .row-domain {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text-hi);
    white-space: nowrap;
  }

  .row.featured .row-domain { color: var(--orange); }

  .badge-rec {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    padding: 1.5px 7px;
    border-radius: 2px;
    background: var(--orange-dim);
    color: var(--orange);
    border: 1px solid var(--orange-border);
    flex-shrink: 0;
  }

  .badge-new {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    padding: 1px 5px;
    border-radius: 2px;
    background: rgba(232,124,30,0.10);
    color: var(--orange);
    border: 1px solid var(--orange-border);
    flex-shrink: 0;
    letter-spacing: 0.5px;
  }

  .row-right {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .arrow { color: var(--orange); opacity: 0.8; }

  /* ── Grid for backups ── */
  .grid-rows {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .grid-rows .row {
    border-right: 1px solid var(--border);
  }

  .grid-rows .row:nth-child(2n) { border-right: none; }
  .grid-rows .row:last-child { border-right: none; }

  /* ── Footer ── */
  .footer {
    margin-top: 28px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--muted);
    line-height: 1.8;
    text-align: center;
  }

  .footer a {
    color: var(--orange);
    text-decoration: none;
  }

  .footer a:hover { text-decoration: underline; }

  @media (max-width: 420px) {
    .countdown { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
</head>
<body>

  <div class="topbar">
    <span class="logo">LIBVIO</span>
    <div class="topbar-status">
      <span class="status-dot"></span>
      域名已停用
    </div>
  </div>

  <div class="main">

    <!-- Alert -->
    <div class="alert">
      <div class="alert-title">
        <span class="status-dot"></span>
        域名停用通知
      </div>
      <div class="domain-strike-row">
        <span class="domain-strike" id="current-domain">libvio.art</span>
        <span class="x-mark">× 已停用</span>
      </div>
      <p class="alert-desc">当前域名即将完全失效，请尽快从下方选择新地址继续访问,最有效是截图保存发布页地址！</p>

      <!-- Countdown -->
      <div class="countdown">
        <div class="countdown-label">
          <span class="status-dot"></span>
          距完全失效
        </div>
        <div class="countdown-time">
          <div class="cd-unit"><span class="cd-num" id="cd-h">--</span><span class="cd-tag">时</span></div>
          <span class="cd-sep">:</span>
          <div class="cd-unit"><span class="cd-num" id="cd-m">--</span><span class="cd-tag">分</span></div>
          <span class="cd-sep">:</span>
          <div class="cd-unit"><span class="cd-num" id="cd-s">--</span><span class="cd-tag">秒</span></div>
        </div>
      </div>
    </div>

    <!-- 发布渠道 -->
    <div class="section">
      <div class="section-head">
        <span class="section-title">发布渠道</span>
      </div>

      <a class="row featured" href="https://libvio.app">
        <div class="row-left">
          <span class="num">—</span>
          <span class="row-domain">libvio.app</span>
          <span class="badge-rec">推荐</span>
        </div>
        <span class="row-right">永久发布页 <span class="arrow">↗</span></span>
      </a>

      <a class="row" href="https://libviofabu.com">
        <div class="row-left">
          <span class="num">A</span>
          <span class="row-domain">libviofabu.com</span>
        </div>
        <span class="row-right">发布页 <span class="arrow">↗</span></span>
      </a>

      <a class="row" href="https://libfabu.com">
        <div class="row-left">
          <span class="num">C</span>
          <span class="row-domain">libfabu.com</span>
        </div>
        <span class="row-right">发布页 <span class="arrow">↗</span></span>
      </a>
    </div>

    <!-- 备用线路 -->
    <div class="section">
      <div class="section-head">
        <span class="section-title">备用线路</span>
      </div>
      <div class="grid-rows">
        <a class="row" target="_blank" href="https://www.libvio.pw">
          <div class="row-left">
            <span class="num">01</span>
            <span class="row-domain">libvio.pw</span>
            <span class="badge-new">NEW</span>
          </div>
        </a>
        <a class="row" target="_blank" href="https://www.libvios.com">
          <div class="row-left">
            <span class="num">02</span>
            <span class="row-domain">libvios.com</span>
            <span class="badge-new">NEW</span>
          </div>
        </a>
        <a class="row" target="_blank" href="https://www.libvio.io">
          <div class="row-left">
            <span class="num">03</span>
            <span class="row-domain">libvio.io</span>
            <span class="badge-new">NEW</span>
          </div>
        </a>
        <a class="row" target="_blank" href="https://libviobd.com">
          <div class="row-left">
            <span class="num">06</span>
            <span class="row-domain">libviobd.com</span>
          </div>
        </a>
        <a class="row" target="_blank" href="https://libhd.com">
          <div class="row-left">
            <span class="num">07</span>
            <span class="row-domain">libhd.com</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      获取不到最新地址？发送邮件至
      <a href="/cdn-cgi/l/email-protection#533b363f23133f3a31253a3c7d303c3e"><span class="__cf_email__" data-cfemail="d4bcb1b8a494b8bdb6a2bdbbfab7bbb9">[email&#160;protected]</span></a>
    </div>

  </div>

<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
  // 当前域名
  (function () {
    const el = document.getElementById('current-domain');
    const host = window.location.hostname;
    if (host && host !== 'localhost' && host !== '127.0.0.1') {
      el.textContent = host;
    }
  })();

  // 随机倒计时:每会话首次访问时,在 4 - 18 小时区间随机生成截止时间,
  // 同一会话内刷新会保持稳定,新标签页/新会话重新随机。
  (function () {
    const KEY = 'libvio-deadline';
    const MIN_H = 4;
    const MAX_H = 18;

    let deadline = parseInt(sessionStorage.getItem(KEY) || '0', 10);
    const now = Date.now();
    if (!deadline || deadline <= now) {
      const seconds = Math.floor(Math.random() * (MAX_H - MIN_H) * 3600 + MIN_H * 3600);
      deadline = now + seconds * 1000;
      try { sessionStorage.setItem(KEY, String(deadline)); } catch (e) {}
    }

    const elH = document.getElementById('cd-h');
    const elM = document.getElementById('cd-m');
    const elS = document.getElementById('cd-s');
    const pad = n => n < 10 ? '0' + n : String(n);

    function tick() {
      let remaining = Math.max(0, Math.floor((deadline - Date.now()) / 1000));
      const h = Math.floor(remaining / 3600);
      const m = Math.floor((remaining % 3600) / 60);
      const s = remaining % 60;
      elH.textContent = pad(h);
      elM.textContent = pad(m);
      elS.textContent = pad(s);
    }

    tick();
    setInterval(tick, 1000);
  })();
</script>
</body>
</html>