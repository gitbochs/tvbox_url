<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>资源加载中 - 请稍候</title>
    <script defer src="https://tj.qhdh.top/script.js" data-website-id="e1eccf76-ba2c-43b9-b9e9-5cd2c8b06610"></script>
    <style>
        /* 延续你喜欢的灰黑色调与高级感 */
        body {
            background-color: #1a1a1a;
            color: #d1d1d1;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }
        .loader {
            width: 48px;
            height: 48px;
            border: 5px solid #333;
            border-bottom-color: #00ffcc; /* 发光特效色 */
            border-radius: 50%;
            display: inline-block;
            box-sizing: border-box;
            animation: rotation 1s linear infinite;
            box-shadow: 0 0 15px rgba(0, 255, 204, 0.2);
        }
        @keyframes rotation {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .tip {
            margin-top: 20px;
            font-size: 14px;
            letter-spacing: 1px;
            opacity: 0.8;
        }
        #btn-manual {
            margin-top: 30px;
            padding: 10px 25px;
            background: transparent;
            border: 1px solid #444;
            color: #888;
            cursor: pointer;
            display: none; /* 探测失败时显示 */
            transition: all 0.3s;
        }
        #btn-manual:hover {
            border-color: #00ffcc;
            color: #00ffcc;
            box-shadow: 0 0 10px rgba(0, 255, 204, 0.3);
        }
    </style>
</head>
<body>

    <span class="loader"></span>
    <div class="tip" id="status-text">安全环境检测中，请稍后...</div>
    <button id="btn-manual" onclick="goToTarget()">手动进入</button>

    <script>
        // 1. 将你的备用域名列表进行 Base64 编码，防止明文被嗅探
        // 比如 https://dy.movie1080.top 编码后是 aHR0cHM6Ly9keS5tb3ZpZTEwODAudG9w
        const DOMAINS_ENCODED = [
            'aHR0cHM6Ly90di5tb3ZpZTEwODAub25saW5lLw==', // 域名A
            'aHR0cHM6Ly90di5tb3ZpZTEwODAub25saW5lLw==', // 域名B
            'aHR0cHM6Ly90di5tb3ZpZTEwODAub25saW5lLw=='     // 域名C
        ];

        let finalUrl = "";

        // 解码函数
        function decode(str) { return atob(str); }

        // 检测函数：尝试加载目标站点的 favicon 或一个小文件
        async function checkDomain(url) {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 3000); // 3秒超时判定为被墙

            try {
                // 使用 no-cors 模式尝试发起请求
                await fetch(url + '/favicon.ico', { mode: 'no-cors', signal: controller.signal });
                return true;
            } catch (e) {
                return false;
            }
        }

        async function init() {
            for (let encoded of DOMAINS_ENCODED) {
                let target = decode(encoded);
                let isAlive = await checkDomain(target);
                
                if (isAlive) {
                    finalUrl = target;
                    document.getElementById('status-text').innerText = "环境校验成功，正在进入...";
                    
                    // 模拟人工延迟，增加隐蔽性
                    setTimeout(() => {
                        window.location.replace(finalUrl); 
                    }, 1500);
                    return;
                }
            }
            
            // 如果都失败了
            document.getElementById('status-text').innerText = "当前线路拥挤，请尝试手动进入";
            document.getElementById('btn-manual').style.display = "block";
            finalUrl = decode(DOMAINS_ENCODED[0]); // 默认第一个
        }

        function goToTarget() {
            if(finalUrl) window.location.href = finalUrl;
        }

        window.onload = init;
    </script>
</body>
</html>