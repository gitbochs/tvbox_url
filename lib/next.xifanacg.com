o-transparent md:from-background/85 md:via-background/40 md:to-transparent"></div><div aria-roledescription="slide" aria-label="1 / 6: 葬送的芙莉莲 第二季" class="relative z-10 mx-auto flex h-full max-w-7xl flex-col justify-end gap-4 px-5 pb-24 md:grid md:grid-cols-[3fr_2fr] md:items-center md:gap-12 md:px-20 md:pt-32 md:pb-16" style="opacity:1;transform:none"><div class="flex flex-col gap-4 md:gap-5"><h2 class="text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl" style="opacity:1;transform:none">葬送的芙莉莲 第二季</h2><div class="flex flex-wrap items-center gap-2" style="opacity:1;transform:none"><span class="rounded-full border border-foreground/15 bg-background/60 px-3 py-1 text-xs text-foreground/80">漫画改</span><span class="rounded-full border border-foreground/15 bg-background/60 px-3 py-1 text-xs text-foreground/80">奇幻</span></div><div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-ink-muted" style="opacity:1;transform:none"><span class="inline-flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="size-4 text-[var(--color-brand-500)]" aria-hidden="true"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm40.55,110.58-52,36A8,8,0,0,1,104,164V92a8,8,0,0,1,12.55-6.58l52,36a8,8,0,0,1,0,13.16Z"></path></svg>全 10 集</span><span class="inline-flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="size-4" aria-hidden="true"><path d="M247.31,124.76c-.35-.79-8.82-19.58-27.65-38.41C194.57,61.26,162.88,48,128,48S61.43,61.26,36.34,86.35C17.51,105.18,9,124,8.69,124.76a8,8,0,0,0,0,6.5c.35.79,8.82,19.57,27.65,38.4C61.43,194.74,93.12,208,128,208s66.57-13.26,91.66-38.34c18.83-18.83,27.3-37.61,27.65-38.4A8,8,0,0,0,247.31,124.76ZM128,192c-30.78,0-57.67-11.19-79.93-33.25A133.47,133.47,0,0,1,25,128,133.33,133.33,0,0,1,48.07,97.25C70.33,75.19,97.22,64,128,64s57.67,11.19,79.93,33.25A133.46,133.46,0,0,1,231.05,128C223.84,141.46,192.43,192,128,192Zm0-112a48,48,0,1,0,48,48A48.05,48.05,0,0,0,128,80Zm0,80a32,32,0,1,1,32-32A32,32,0,0,1,128,160Z"></path></svg>36.7万<!-- --> 次播放</span></div><p class="line-clamp-3 max-w-prose text-sm leading-relaxed text-foreground/80 md:text-base" style="opacity:1;transform:none">芙莉莲是一位千年精灵魔法使，曾与勇者辛美尔一同击败魔王。在见证辛美尔寿终正寝后，她踏上理解人类心灵的旅程，与魔法使菲伦、战士休塔尔克结伴前往灵魂安眠之地奥伊伦。这段旅途充满温馨日常与激烈战斗，每个瞬间都在三人之间筑起无可替代的羁绊。</p><div class="pt-1" style="opacity:1;transform:none"><a aria-label="观看 葬送的芙莉莲 第二季" class="block sm:inline-block" href="/anime/3252"><button data-slot="button" class="button button--lg button--primary w-full transition-transform duration-200 active:scale-[0.97] sm:w-auto" data-rac="" type="button" tabindex="0" data-react-aria-pressable="true" id="react-aria-_R_5bf51aul5b_"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" class="size-5" aria-hidden="true"><path d="M240,128a15.74,15.74,0,0,1-7.6,13.51L88.32,229.65a16,16,0,0,1-16.2.3A15.86,15.86,0,0,1,64,216.13V39.87a15.86,15.86,0,0,1,8.12-13.82,16,16,0,0,1,16.2.3L232.4,114.49A15.74,15.74,0,0,1,240,128Z"></path></svg>立即观看</button></a></div></div><div class="hidden justify-end md:flex" style="opacity:1;transform:none"><div class="group/poster relative aspect-[2/3] w-full max-w-[280px] overflow-hidden rounded-2xl shadow-2xl ring-1 ring-foreground/10 transition-transform duration-300 ease-out hover:-rotate-[0.5deg] hover:scale-[1.03]"><img alt="葬送的芙莉莲 第二季" decoding="async" data-nimg="fill" class="object-cover" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent" sizes="(min-width: 768px) 280px, 0px" srcSet="/_next/image?url=https%3A%2F%2Fimg2.cycimg.me%2Fr%2F800%2Fpic%2Fcover%2Fl%2F0b%2F24%2F515759_qA1Zc.jpg&amp;w=32&amp;q=75 32w, /_next/image?url=https%3A%2F%2Fimg2.cycimg.me%2Fr%2F800%2Fpic%2Fcover%2Fl%2F0b%2F24%2F515759_qA1Zc.jpg&amp;w=48&amp;q=75 48w, /_next/image?url=https%3A