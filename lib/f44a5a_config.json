    if(activeBox){
      activeBox.setAttribute('style',savedBoxStyle||'');
      delete activeBox.dataset.gimyYtWebFullscreen;
    }
    if(savedOverflow){
      document.documentElement.style.overflow=savedOverflow.html;
      if(document.body)document.body.style.overflow=savedOverflow.body;
    }
    activeFrame=null;
    activeBox=null;
    savedFrameStyle='';
    savedBoxStyle='';
    savedOverflow=null;
  }
  window.addEventListener('message',function(event){
    var data=event.data||{};
    var isYtPlayer=data.source==='gimy-yt-player'&&data.type==='web-fullscreen';
    var isPlayerWrapper=data.type==='player:fullscreenWeb';
    if(!data||(!isYtPlayer&&!isPlayerWrapper))return;
    if(event.origin!=='https://v.gimy.bot'&&event.origin!=='https://player.gimy.bot')return;
    var frame=findPlayerFrame(event.source);
    if(!frame)return;
    if(!(isYtPlayer?data.enabled:data.state)){
      restore();
      return;
    }
    if(activeFrame&&activeFrame!==frame)restore();
    activeFrame=frame;
    activeBox=frame.closest('#player-frame,.player-frame,.watch-player')||frame.parentElement;
    savedFrameStyle=frame.getAttribute('style')||'';
    savedBoxStyle=activeBox?activeBox.getAttribute('style')||'':'';
    savedOverflow={
      html:document.documentElement.style.overflow||'',
      body:document.body?document.body.style.overflow||'':''
    };
    if(activeBox){
      activeBox.dataset.gimyYtWebFullscreen='1';
      activeBox.style.position='fixed';
      activeBox.style.inset='0';
      activeBox.style.width='100vw';
      activeBox.style.height='100vh';
      activeBox.style.maxWidth='none';
      activeBox.style.maxHeight='none';
      activeBox.style.margin='0';
      activeBox.style.padding='0';
      activeBox.style.borderRadius='0';
      activeBox.style.overflow='hidden';
      activeBox.style.zIndex='2147483000';
      activeBox.style.background='#000';
      activeBox.style.isolation='auto';
    }
    frame.dataset.gimyYtWebFullscreen='1';
    frame.style.position='absolute';
    frame.style.inset='0';
    frame.style.width='100%';
    frame.style.height='100%';
    frame.style.maxWidth='none';
    frame.style.maxHeight='none';
    frame.style.zIndex='1';
    frame.style.background='#000';
    frame.style.border='0';
    document.documentElement.style.overflow='hidden';
    if(document.body)document.body.style.overflow='hidden';
  });
  window.addEventListener('keydown',function(event){
    if(event.key==='Escape')restore();
  });
})();
</script>
<script>
(function(){
  var KEY='pwa_dismiss',DAYS=1,dp=null;
  var sb=document.querySelector('[data-install-banner]'),ios=document.querySelector('[data-ios-hint]');
  var acts=document.querySelectorAll('[data-install-action]');
  if(window.matchMedia('(display-mode: standalone)').matches||navigator.standalone===true)return;
  var ua=navigator.userAgent||'';
  var isIOS=/iphone|ipad|ipod/i.test(ua)||(/Macintosh/i.test(ua)&&navigator.maxTouchPoints>1);
  var isMobile=window.matchMedia('(pointer: coarse)').matches;
  function dismissed(){try{var v=localStorage.getItem(KEY);return v&&(Date.now()-+v)<DAYS*864e5;}catch(e){return false;}}
  function showBanner(){if(sb&&!dismissed()){sb.hidden=false;requestAnimationFrame(function(){sb.classList.add('show');});}}
  function hideBanner(){if(sb){sb.classList.remove('show');setTimeout(function(){sb.hidden=true;},250);}}
  window.addEventListener('beforeinstallprompt',function(e){if(!isMobile)return;e.preventDefault();dp=e;setTimeout(showBanner,3000);});
  acts.forEach(function(b){b.addEventListener('click',function(){if(dp){dp.prompt();dp.userChoice.then(function(){dp=null;hideBanner();});}else if(isIOS&&ios){hideBanner();ios.hidden=false;}});});
  var dm=document.querySelector('[data-install-dismiss]');if(dm)dm.addEventListener('click',function(){try{localStorage.setItem(KEY,String(Date.now()));}catch(e){}hideBanner();});
  var ic=document.querySelector('[data-ios-hint-close]');if(ic)ic.addEventListener('click',function(){if(ios)ios.hidden=true;});
  if(ios)ios.addEventListener('click',function(e){if(e.target===ios)ios.hidden=true;});
  window.addEventListener('appinstalled',function(){hideBanner();acts.forEach(function(b){b.hidden=true;});});
})();
</script>
<script>
(function(){
  var KEY='gimy_zh',MAPKEY='gimy_t2s_v1';
  var btn=document.querySelector('[data-zh-toggle]'),lbl=document.querySelector('[data-zh-label]');
  var map=null,observing=false;
  var SKIP={SCRIPT:1,STYLE:1,NOSCRIPT:1,TEXTAREA:1,CODE:1,PRE:1};
  function conv(s){var o='';for(var i=0;i<s.length;i++){var c=s.charAt(i);o+=map[c]||c;}return o;}
  function walk(root){
    if(root.nodeType===3){var c=conv(root.nodeValue);if(c!==root.nodeValue)root.nodeValue=c;return;}
    if(root.nodeType!==1||SKIP[root.nodeName])return;
    var w=document.createTreeWalker(root,NodeFilter.SHOW_TEXT,{acceptNode:function(n){
      if(!n.nodeValue||!n.nodeValue.trim())return NodeFilter.FILTER_REJECT;
      return (n.parentNode&&SKIP[n.parentNode.nodeName])?NodeFilter.FILTER_REJECT:NodeFilter.FILTER_ACCEPT;}});
    var n,a=[];while(n=w.nextNode())a.push(n);
    for(var i=0;i<a.length;i++){var c=conv(a[i].nodeValue);if(c!==a[i].nodeValue)a[i].nodeValue=c;}
  }
  function convertAll(){
    if(lbl)lbl.textContent='繁體中文';
    walk(document.body);
    document.documentElement.lang='zh-Hans';
    if(!observing){observing=true;
      new MutationObserver(function(ms){for(var i=0;i<ms.length;i++){var ns=ms[i].addedNodes;for(var j=0;j<ns.length;j++)walk(ns[j]);}}).observe(document.body,{childList:true,subtree:true});}
  }
  function loadMap(cb){
    if(map)return cb();
    try{var c=localStorage.getItem(MAPKEY);if(c){map=JSON.parse(c);return cb();}}catch(e){}
    fetch('/template/gimyai/js/t2s.json?v=1').then(function(r){return r.json();}).then(function(j){map=j;try{localStorage.setItem(MAPKEY,JSON.stringify(j));}catch(e){}cb();}).catch(function(){});
  }
  var active=false;try{active=localStorage.getItem(KEY)==='s';}catch(e){}
  if(active)loadMap(convertAll);
  if(btn)btn.addEventListener('click',function(){
    try{localStorage.getItem(KEY)==='s'?localStorage.removeItem(KEY):localStorage.setItem(KEY,'s');}catch(e){}
    location.reload();
  });
})();
</script>
<script>/* vod-vote */
(function(){
  function gc(n){var m=document.cookie.match('(^|;)\\s*'+n+'\\s*=\\s*([^;]+)');return m?decodeURIComponent(m.pop()):'';}
  var EP='/index.php/ajax/digg';
  function post(id,type){return fetch(EP,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded','X-Requested-With':'XMLHttpRequest'},credentials:'same-origin',body:'id='+encodeURIComponent(id)+'&mid=1&type='+type}).then(function(r){return r.json();});}
  var gs=document.querySelectorAll('[data-vote]');if(!gs.length)return;
  for(var i=0;i<gs.length;i++)(function(g){
    var id=g.getAttribute('data-id');if(!id)return;
    var up=g.querySelector('.vote-up'),dn=g.querySelector('.vote-down');
    var nu=up.querySelector('.vote-num'),nd=dn.querySelector('.vote-num');
    function apply(d){if(nu)nu.textContent=d.up>0?d.up:'';if(nd)nd.textContent=d.down>0?d.down:'';up.classList.toggle('is-on',!!d.voted_up);dn.classList.toggle('is-on',!!d.voted_down);}
    var vu=!!gc('vod-up-'+id),vd=!!gc('vod-down-'+id);
    if(vu)up.classList.add('is-on');
    if(vd)dn.classList.add('is-on');
    if(vu||vd){post(id,'').then(function(d){if(d&&d.code==1&&d.data)apply(d.data);}).catch(function(){});}
    g.addEventListener('click',function(e){
      var btn=e.target.closest('[data-vote-type]');if(!btn)return;
      if(g.getAttribute('data-busy'))return;g.setAttribute('data-busy','1');
      post(id,btn.getAttribute('data-vote-type')).then(function(d){g.removeAttribute('data-busy');if(d&&d.code==1&&d.data)apply(d.data);}).catch(function(){g.removeAttribute('data-busy');});
    });
  })(gs[i]);
})();
</script>

</body>
</html>
